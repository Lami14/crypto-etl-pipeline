# Copy this file to .env and fill in your values
# cp .env.example .env

# ─── PostgreSQL ───────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crypto_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# ─── CoinGecko (optional - free tier needs no key) ────────────
COINGECKO_API_KEY=

# ─── Airflow ──────────────────────────────────────────────────
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
